            (clear-relation :schema NextSiblingAnc :ver NEW)
            (merge-index :index (NextSiblingAnc 0 1 2 3))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel NextSiblingAnc :canonical-index (0 1 2 3))
  )
  (step :recursive true
        (fixpoint-plan
            (execute-pipeline :rule NextSiblingAnc2_D0
              :sources (tuple
                (index-spec :schema NextSiblingAnc :index (0 1 2 3) :ver DELTA)
                (index-spec :schema NotSiblingInsert :index (2 3 0 1) :ver FULL)
                (index-spec :schema NextSiblingAnc :index (0 1 2 3) :ver DELTA)
                (index-spec :schema NotSiblingInsert :index (2 3 0 1) :ver FULL)
                (index-spec :schema NextSiblingAnc :index (0 1 2 3) :ver DELTA)
                (index-spec :schema NotSiblingInsert :index (2 3 0 1) :ver FULL))
              :dests (tuple
                (index-spec :schema NextSiblingAnc :index (0 1 2 3) :ver FULL))
                (column-join :var ParentCtr
                  :sources (
                    (column-source :index (NextSiblingAnc 0 1 2 3) :ver DELTA :prefix ())
                    (column-source :index (NotSiblingInsert 2 3 0 1) :ver FULL :prefix ())
                  ))
                (column-join :var ParentN
                  :sources (
                    (column-source :index (NextSiblingAnc 0 1 2 3) :ver DELTA :prefix (ParentCtr))
                    (column-source :index (NotSiblingInsert 2 3 0 1) :ver FULL :prefix (ParentCtr))
                  ))
                (cartesian-join :vars (NextCtr NextN StartCtr StartN) :var-from-source ((NextCtr NextN) (StartCtr StartN))
                  :sources (
                    (column-source :index (NextSiblingAnc 0 1 2 3) :ver DELTA :prefix (ParentCtr ParentN))
                    (column-source :index (NotSiblingInsert 2 3 0 1) :ver FULL :prefix (ParentCtr ParentN))
                  ))
                (insert-into :schema NextSiblingAnc :ver NEW :dedup-index (0 1 2 3) :terms (StartCtr StartN NextCtr NextN))
