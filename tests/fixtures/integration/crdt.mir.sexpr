                    (scan :vars (Ctr1 N1 Ctr2 N2) :index (Sibling 0 1 2 3) :ver FULL :prefix ())
                    (filter :vars (Ctr1 N1 Ctr2 N2) :code "return (Ctr1 * 10 + N1) > (Ctr2 * 10 + N2);")
                    (insert-into :schema LaterSibling :ver NEW :dedup-index (0 1 2 3) :terms (Ctr1 N1 Ctr2 N2))
                )
                (execute-pipeline :rule LaterSibling2
                  :sources (tuple
                    (index-spec :schema Sibling :index (0 1 2 3) :ver FULL)
                    (index-spec :schema Sibling :index (0 1 2 3) :ver FULL)
                    (index-spec :schema Sibling :index (0 1 2 3) :ver FULL)
                    (index-spec :schema Sibling :index (0 1 2 3) :ver FULL)
                    (index-spec :schema Sibling :index (0 1 2 3) :ver FULL)
                    (index-spec :schema Sibling :index (0 1 2 3) :ver FULL))
                  :dests (tuple
                    (index-spec :schema LaterSibling2 :index (0 1 2 3) :ver FULL))
                    (column-join :var Ctr1
                      :sources (
                        (column-source :index (Sibling 0 1 2 3) :ver FULL :prefix ())
                        (column-source :index (Sibling 0 1 2 3) :ver FULL :prefix ())
                      ))
                    (column-join :var N1
                      :sources (
                        (column-source :index (Sibling 0 1 2 3) :ver FULL :prefix (Ctr1))
                        (column-source :index (Sibling 0 1 2 3) :ver FULL :prefix (Ctr1))
                      ))
                    (cartesian-join :vars (Ctr2 N2 Ctr3 N3) :var-from-source ((Ctr2 N2) (Ctr3 N3))
                      :sources (
                        (column-source :index (Sibling 0 1 2 3) :ver FULL :prefix (Ctr1 N1))
                        (column-source :index (Sibling 0 1 2 3) :ver FULL :prefix (Ctr1 N1))
                      ))
                    (filter :vars (Ctr1 N1 Ctr2 N2) :code "return (Ctr1 * 10 + N1) > (Ctr2 * 10 + N2);")
                    (filter :vars (Ctr2 N2 Ctr3 N3) :code "return (Ctr2 * 10 + N2) > (Ctr3 * 10 + N3);")
                    (insert-into :schema LaterSibling2 :ver NEW :dedup-index (0 1 2 3) :terms (Ctr1 N1 Ctr3 N3))
                )
            )
            (rebuild-index :index (LaterSibling 0 1 2 3) :ver NEW)
            (check-size :schema LaterSibling :ver NEW)
            (compute-delta-index :schema LaterSibling :canonical-index (0 1 2 3))
            (clear-relation :schema LaterSibling :ver NEW)
            (merge-index :index (LaterSibling 0 1 2 3))
            (rebuild-index :index (LaterSibling2 0 1 2 3) :ver NEW)
            (check-size :schema LaterSibling2 :ver NEW)
            (compute-delta-index :schema LaterSibling2 :canonical-index (0 1 2 3))
            (clear-relation :schema LaterSibling2 :ver NEW)
            (merge-index :index (LaterSibling2 0 1 2 3))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel LaterSibling :canonical-index (0 1 2 3))
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel LaterSibling2 :canonical-index (0 1 2 3))
  )
  (step :recursive false
        (fixpoint-plan
            (parallel-group  ;; 2 independent ops
                (execute-pipeline :rule NextSibling
                  :sources (tuple
                    (index-spec :schema LaterSibling :index (0 1 2 3) :ver FULL)
                    (index-spec :schema LaterSibling2 :index (0 1 2 3) :ver FULL))
                  :dests (tuple
                    (index-spec :schema NextSibling :index (0 1 2 3) :ver FULL))
                    (scan :vars (Ctr1 N1 Ctr2 N2) :index (LaterSibling 0 1 2 3) :ver FULL :prefix ())
                    (negation :schema LaterSibling2 :ver FULL :index (LaterSibling2 0 1 2 3) :prefix (Ctr1 N1 Ctr2 N2))
                    (insert-into :schema NextSibling :ver NEW :dedup-index (0 1 2 3) :terms (Ctr1 N1 Ctr2 N2))
                )
                (execute-pipeline :rule HasNextSibling
                  :sources (tuple
                    (index-spec :schema LaterSibling :index (0 1 2 3) :ver FULL))
                  :dests (tuple
                    (index-spec :schema HasNextSibling :index (0 1) :ver FULL))
                    (scan :vars (SibCtr1 SibN1 _gen1 _gen2) :index (LaterSibling 0 1 2 3) :ver FULL :prefix ())
                    (insert-into :schema HasNextSibling :ver NEW :dedup-index (0 1) :terms (SibCtr1 SibN1))
                )
            )
            (rebuild-index :index (NextSibling 0 1 2 3) :ver NEW)
            (check-size :schema NextSibling :ver NEW)
            (compute-delta-index :schema NextSibling :canonical-index (0 1 2 3))
            (clear-relation :schema NextSibling :ver NEW)
            (merge-index :index (NextSibling 0 1 2 3))
            (rebuild-index :index (HasNextSibling 0 1) :ver NEW)
            (check-size :schema HasNextSibling :ver NEW)
            (compute-delta-index :schema HasNextSibling :canonical-index (0 1))
            (clear-relation :schema HasNextSibling :ver NEW)
            (merge-index :index (HasNextSibling 0 1))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel NextSibling :canonical-index (0 1 2 3))
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel HasNextSibling :canonical-index (0 1))
  )
  (step :recursive false
        (fixpoint-plan
            (execute-pipeline :rule NotSiblingInsert
              :sources (tuple
                (index-spec :schema Insert :index (0 1 2 3) :ver FULL)
                (index-spec :schema HasNextSibling :index (0 1) :ver FULL))
              :dests (tuple
                (index-spec :schema NotSiblingInsert :index (2 3 0 1) :ver FULL))
                (scan :vars (Ctr1 N1 Ctr2 N2) :index (Insert 0 1 2 3) :ver FULL :prefix ())
                (negation :schema HasNextSibling :ver FULL :index (HasNextSibling 0 1) :prefix (Ctr1 N1))
                (insert-into :schema NotSiblingInsert :ver NEW :dedup-index (2 3 0 1) :terms (Ctr1 N1 Ctr2 N2))
            )
            (rebuild-index :index (NotSiblingInsert 2 3 0 1) :ver NEW)
            (check-size :schema NotSiblingInsert :ver NEW)
            (compute-delta-index :schema NotSiblingInsert :canonical-index (2 3 0 1))
            (clear-relation :schema NotSiblingInsert :ver NEW)
            (merge-index :index (NotSiblingInsert 2 3 0 1))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel NotSiblingInsert :canonical-index (2 3 0 1))
  )
  (step :recursive false
        (fixpoint-plan
            (execute-pipeline :rule NextSiblingAnc1
              :sources (tuple
                (index-spec :schema NextSibling :index (0 1 2 3) :ver FULL))
              :dests (tuple
                (index-spec :schema NextSiblingAnc :index (0 1 2 3) :ver FULL))
                (scan :vars (StartCtr StartN NextCtr NextN) :index (NextSibling 0 1 2 3) :ver FULL :prefix ())
                (insert-into :schema NextSiblingAnc :ver NEW :dedup-index (0 1 2 3) :terms (StartCtr StartN NextCtr NextN))
