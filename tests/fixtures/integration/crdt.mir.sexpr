                (cartesian-join :vars (ToCtr ToN FromCtr FromN) :var-from-source ((ToCtr ToN) (FromCtr FromN))
                  :sources (
                    (column-source :index (SkipBlank 0 1 2 3) :ver DELTA :prefix (ViaCtr ViaN))
                    (column-source :index (NotHasValueNextElem 2 3 0 1) :ver FULL :prefix (ViaCtr ViaN))
                  ))
                (insert-into :schema SkipBlank :ver NEW :dedup-index (0 1 2 3) :terms (FromCtr FromN ToCtr ToN))
            )
            (inject-cpp-hook :rule SkipBlank2 :code "...")
            (rebuild-index :index (SkipBlank 0 1 2 3) :ver NEW)
            (clear-relation :schema SkipBlank :ver DELTA)
            (check-size :schema SkipBlank :ver NEW)
            (compute-delta-index :schema SkipBlank :canonical-index (0 1 2 3))
            (clear-relation :schema SkipBlank :ver NEW)
            (merge-index :index (SkipBlank 0 1 2 3))
