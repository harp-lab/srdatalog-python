            (clear-relation :schema NextElem :ver NEW)
            (merge-index :index (NextElem 0 1 2 3))
            (rebuild-index :index (NextElem 0 1 2 3) :ver NEW)
            (check-size :schema NextElem :ver NEW)
            (compute-delta-index :schema NextElem :canonical-index (0 1 2 3))
            (clear-relation :schema NextElem :ver NEW)
