(program
  (step :recursive false
        (fixpoint-plan
            (parallel-group  ;; 2 independent ops
                (execute-pipeline :rule Insert
                  :sources (tuple
                    (index-spec :schema InsertInput :index (0 1 2 3) :ver FULL))
                  :dests (tuple
                    (index-spec :schema Insert :index (2 3 0 1) :ver FULL))
                    (scan :vars (a b c d) :index (InsertInput 0 1 2 3) :ver FULL :prefix ())
                    (insert-into :schema Insert :ver NEW :dedup-index (2 3 0 1) :terms (a b c d))
                )
                (execute-pipeline :rule Remove
                  :sources (tuple
                    (index-spec :schema RemoveInput :index (0 1) :ver FULL))
                  :dests (tuple
                    (index-spec :schema Remove :index (0 1) :ver FULL))
                    (scan :vars (a b) :index (RemoveInput 0 1) :ver FULL :prefix ())
                    (insert-into :schema Remove :ver NEW :dedup-index (0 1) :terms (a b))
                )
            )
            (rebuild-index :index (Insert 2 3 0 1) :ver NEW)
            (check-size :schema Insert :ver NEW)
            (compute-delta-index :schema Insert :canonical-index (2 3 0 1))
            (clear-relation :schema Insert :ver NEW)
            (merge-index :index (Insert 2 3 0 1))
            (rebuild-index-from-index :source (Insert 2 3 0 1) :target (Insert 0 1 2 3) :ver DELTA)
            (merge-index :index (Insert 0 1 2 3))
            (rebuild-index :index (Remove 0 1) :ver NEW)
            (check-size :schema Remove :ver NEW)
            (compute-delta-index :schema Remove :canonical-index (0 1))
            (clear-relation :schema Remove :ver NEW)
            (merge-index :index (Remove 0 1))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel Insert :canonical-index (2 3 0 1))
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel Remove :canonical-index (0 1))
  )
  (step :recursive false
        (fixpoint-plan
            (execute-pipeline :rule LaterChild
              :sources (tuple
                (index-spec :schema Insert :index (2 3 0 1) :ver FULL)
                (index-spec :schema Insert :index (2 3 0 1) :ver FULL)
                (index-spec :schema Insert :index (2 3 0 1) :ver FULL)
                (index-spec :schema Insert :index (2 3 0 1) :ver FULL)
                (index-spec :schema Insert :index (2 3 0 1) :ver FULL)
                (index-spec :schema Insert :index (2 3 0 1) :ver FULL))
              :dests (tuple
                (index-spec :schema LaterChild :index (2 3 0 1) :ver FULL))
                (column-join :var ParentCtr
                  :sources (
                    (column-source :index (Insert 2 3 0 1) :ver FULL :prefix ())
                    (column-source :index (Insert 2 3 0 1) :ver FULL :prefix ())
                  ))
                (column-join :var ParentN
                  :sources (
                    (column-source :index (Insert 2 3 0 1) :ver FULL :prefix (ParentCtr))
                    (column-source :index (Insert 2 3 0 1) :ver FULL :prefix (ParentCtr))
                  ))
                (cartesian-join :vars (Ctr1 N1 Ctr2 N2) :var-from-source ((Ctr1 N1) (Ctr2 N2))
                  :sources (
                    (column-source :index (Insert 2 3 0 1) :ver FULL :prefix (ParentCtr ParentN))
                    (column-source :index (Insert 2 3 0 1) :ver FULL :prefix (ParentCtr ParentN))
                  ))
                (filter :vars (Ctr1 N1 Ctr2 N2) :code "return (Ctr1 * 10 + N1) > (Ctr2 * 10 + N2);")
                (insert-into :schema LaterChild :ver NEW :dedup-index (2 3 0 1) :terms (ParentCtr ParentN Ctr2 N2))
            )
            (rebuild-index :index (LaterChild 2 3 0 1) :ver NEW)
            (check-size :schema LaterChild :ver NEW)
            (compute-delta-index :schema LaterChild :canonical-index (2 3 0 1))
            (clear-relation :schema LaterChild :ver NEW)
            (merge-index :index (LaterChild 2 3 0 1))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel LaterChild :canonical-index (2 3 0 1))
  )
  (step :recursive false
        (fixpoint-plan
            (parallel-group  ;; 2 independent ops
                (execute-pipeline :rule FirstChild
                  :sources (tuple
                    (index-spec :schema Insert :index (0 1 2 3) :ver FULL)
                    (index-spec :schema LaterChild :index (2 3 0 1) :ver FULL))
                  :dests (tuple
                    (index-spec :schema FirstChild :index (0 1 2 3) :ver FULL))
                    (scan :vars (ChildCtr ChildN ParentCtr ParentN) :index (Insert 0 1 2 3) :ver FULL :prefix ())
                    (negation :schema LaterChild :ver FULL :index (LaterChild 2 3 0 1) :prefix (ChildCtr ChildN ParentCtr ParentN))
                    (insert-into :schema FirstChild :ver NEW :dedup-index (0 1 2 3) :terms (ParentCtr ParentN ChildCtr ChildN))
                )
                (execute-pipeline :rule Sibling
                  :sources (tuple
                    (index-spec :schema Insert :index (2 3 0 1) :ver FULL)
                    (index-spec :schema Insert :index (2 3 0 1) :ver FULL)
                    (index-spec :schema Insert :index (2 3 0 1) :ver FULL)
                    (index-spec :schema Insert :index (2 3 0 1) :ver FULL)
                    (index-spec :schema Insert :index (2 3 0 1) :ver FULL)
                    (index-spec :schema Insert :index (2 3 0 1) :ver FULL))
                  :dests (tuple
                    (index-spec :schema Sibling :index (0 1 2 3) :ver FULL))
                    (column-join :var ParentCtr
                      :sources (
                        (column-source :index (Insert 2 3 0 1) :ver FULL :prefix ())
                        (column-source :index (Insert 2 3 0 1) :ver FULL :prefix ())
                      ))
                    (column-join :var ParentN
                      :sources (
                        (column-source :index (Insert 2 3 0 1) :ver FULL :prefix (ParentCtr))
                        (column-source :index (Insert 2 3 0 1) :ver FULL :prefix (ParentCtr))
                      ))
                    (cartesian-join :vars (ChildCtr1 ChildN1 ChildCtr2 ChildN2) :var-from-source ((ChildCtr1 ChildN1) (ChildCtr2 ChildN2))
                      :sources (
                        (column-source :index (Insert 2 3 0 1) :ver FULL :prefix (ParentCtr ParentN))
                        (column-source :index (Insert 2 3 0 1) :ver FULL :prefix (ParentCtr ParentN))
                      ))
                    (insert-into :schema Sibling :ver NEW :dedup-index (0 1 2 3) :terms (ChildCtr1 ChildN1 ChildCtr2 ChildN2))
                )
            )
            (rebuild-index :index (FirstChild 0 1 2 3) :ver NEW)
            (check-size :schema FirstChild :ver NEW)
            (compute-delta-index :schema FirstChild :canonical-index (0 1 2 3))
            (clear-relation :schema FirstChild :ver NEW)
            (merge-index :index (FirstChild 0 1 2 3))
            (rebuild-index :index (Sibling 0 1 2 3) :ver NEW)
            (check-size :schema Sibling :ver NEW)
            (compute-delta-index :schema Sibling :canonical-index (0 1 2 3))
            (clear-relation :schema Sibling :ver NEW)
            (merge-index :index (Sibling 0 1 2 3))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel FirstChild :canonical-index (0 1 2 3))
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel Sibling :canonical-index (0 1 2 3))
  )
  (step :recursive false
        (fixpoint-plan
