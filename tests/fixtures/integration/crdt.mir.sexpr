  (step :recursive false
        (fixpoint-plan
            (execute-pipeline :rule SkipBlank1
              :sources (tuple
                (index-spec :schema NextElem :index (0 1 2 3) :ver FULL))
              :dests (tuple
                (index-spec :schema SkipBlank :index (0 1 2 3) :ver FULL))
                (scan :vars (FromCtr FromN ToCtr ToN) :index (NextElem 0 1 2 3) :ver FULL :prefix ())
                (insert-into :schema SkipBlank :ver NEW :dedup-index (0 1 2 3) :terms (FromCtr FromN ToCtr ToN))
