(program
  (step :recursive false
        (fixpoint-plan
            (parallel-group  ;; 12 independent ops
                (execute-pipeline :rule isType_Class
                  :sources (tuple
                    (index-spec :schema ClassType :index (0) :ver FULL))
                  :dests (tuple
                    (index-spec :schema isType :index (0) :ver FULL))
                    (scan :vars (class) :index (ClassType 0) :ver FULL :prefix ())
                    (insert-into :schema isType :ver NEW :dedup-index (0) :terms (class))
                )
                (execute-pipeline :rule isType_Array
                  :sources (tuple
                    (index-spec :schema ArrayType :index (0) :ver FULL))
                  :dests (tuple
                    (index-spec :schema isType :index (0) :ver FULL))
                    (scan :vars (arr) :index (ArrayType 0) :ver FULL :prefix ())
                    (insert-into :schema isType :ver NEW :dedup-index (0) :terms (arr))
                )
                (execute-pipeline :rule isType_Interface
                  :sources (tuple
                    (index-spec :schema InterfaceType :index (0) :ver FULL))
                  :dests (tuple
                    (index-spec :schema isType :index (0) :ver FULL))
                    (scan :vars (iface) :index (InterfaceType 0) :ver FULL :prefix ())
                    (insert-into :schema isType :ver NEW :dedup-index (0) :terms (iface))
                )
                (execute-pipeline :rule isType_AppClass
                  :sources (tuple
                    (index-spec :schema ApplicationClass :index (0) :ver FULL))
                  :dests (tuple
                    (index-spec :schema isType :index (0) :ver FULL))
                    (scan :vars (t) :index (ApplicationClass 0) :ver FULL :prefix ())
                    (insert-into :schema isType :ver NEW :dedup-index (0) :terms (t))
                )
                (execute-pipeline :rule isRefType_Class
                  :sources (tuple
                    (index-spec :schema ClassType :index (0) :ver FULL))
                  :dests (tuple
                    (index-spec :schema isReferenceType :index (0) :ver FULL))
                    (scan :vars (class) :index (ClassType 0) :ver FULL :prefix ())
                    (insert-into :schema isReferenceType :ver NEW :dedup-index (0) :terms (class))
                )
                (execute-pipeline :rule isRefType_Array
                  :sources (tuple
                    (index-spec :schema ArrayType :index (0) :ver FULL))
                  :dests (tuple
                    (index-spec :schema isReferenceType :index (0) :ver FULL))
                    (scan :vars (arr) :index (ArrayType 0) :ver FULL :prefix ())
                    (insert-into :schema isReferenceType :ver NEW :dedup-index (0) :terms (arr))
                )
                (execute-pipeline :rule isRefType_Interface
                  :sources (tuple
                    (index-spec :schema InterfaceType :index (0) :ver FULL))
                  :dests (tuple
                    (index-spec :schema isReferenceType :index (0) :ver FULL))
                    (scan :vars (iface) :index (InterfaceType 0) :ver FULL :prefix ())
                    (insert-into :schema isReferenceType :ver NEW :dedup-index (0) :terms (iface))
                )
                (execute-pipeline :rule isRefType_AppClass
                  :sources (tuple
                    (index-spec :schema ApplicationClass :index (0) :ver FULL))
                  :dests (tuple
                    (index-spec :schema isReferenceType :index (0) :ver FULL))
                    (scan :vars (t) :index (ApplicationClass 0) :ver FULL :prefix ())
                    (insert-into :schema isReferenceType :ver NEW :dedup-index (0) :terms (t))
                )
                (execute-pipeline :rule isClassType
                  :sources (tuple
                    (index-spec :schema ClassType :index (0) :ver FULL))
                  :dests (tuple
                    (index-spec :schema isClassType_IDB :index (0) :ver FULL))
                    (scan :vars (class) :index (ClassType 0) :ver FULL :prefix ())
                    (insert-into :schema isClassType_IDB :ver NEW :dedup-index (0) :terms (class))
                )
                (execute-pipeline :rule isArrayType
                  :sources (tuple
                    (index-spec :schema ArrayType :index (0) :ver FULL))
                  :dests (tuple
                    (index-spec :schema isArrayType_IDB :index (0) :ver FULL))
                    (scan :vars (arr) :index (ArrayType 0) :ver FULL :prefix ())
                    (insert-into :schema isArrayType_IDB :ver NEW :dedup-index (0) :terms (arr))
                )
                (execute-pipeline :rule isInterfaceType
                  :sources (tuple
                    (index-spec :schema InterfaceType :index (0) :ver FULL))
                  :dests (tuple
                    (index-spec :schema isInterfaceType_IDB :index (0) :ver FULL))
                    (scan :vars (iface) :index (InterfaceType 0) :ver FULL :prefix ())
                    (insert-into :schema isInterfaceType_IDB :ver NEW :dedup-index (0) :terms (iface))
                )
                (execute-pipeline :rule DirectSubclass
                  :sources (tuple
                    (index-spec :schema DirectSuperclass :index (0 1) :ver FULL))
                  :dests (tuple
                    (index-spec :schema DirectSubclass :index (0 1) :ver FULL))
                    (scan :vars (a c) :index (DirectSuperclass 0 1) :ver FULL :prefix ())
                    (insert-into :schema DirectSubclass :ver NEW :dedup-index (0 1) :terms (a c))
                )
            )
            (rebuild-index :index (isType 0) :ver NEW)
            (check-size :schema isType :ver NEW)
            (compute-delta-index :schema isType :canonical-index (0))
            (clear-relation :schema isType :ver NEW)
            (merge-index :index (isType 0))
            (rebuild-index :index (isType 0) :ver NEW)
            (check-size :schema isType :ver NEW)
            (compute-delta-index :schema isType :canonical-index (0))
            (clear-relation :schema isType :ver NEW)
            (merge-index :index (isType 0))
            (rebuild-index :index (isType 0) :ver NEW)
            (check-size :schema isType :ver NEW)
            (compute-delta-index :schema isType :canonical-index (0))
            (clear-relation :schema isType :ver NEW)
            (merge-index :index (isType 0))
            (rebuild-index :index (isType 0) :ver NEW)
            (check-size :schema isType :ver NEW)
            (compute-delta-index :schema isType :canonical-index (0))
            (clear-relation :schema isType :ver NEW)
            (merge-index :index (isType 0))
            (rebuild-index :index (isReferenceType 0) :ver NEW)
            (check-size :schema isReferenceType :ver NEW)
            (compute-delta-index :schema isReferenceType :canonical-index (0))
            (clear-relation :schema isReferenceType :ver NEW)
            (merge-index :index (isReferenceType 0))
            (rebuild-index :index (isReferenceType 0) :ver NEW)
            (check-size :schema isReferenceType :ver NEW)
            (compute-delta-index :schema isReferenceType :canonical-index (0))
            (clear-relation :schema isReferenceType :ver NEW)
            (merge-index :index (isReferenceType 0))
            (rebuild-index :index (isReferenceType 0) :ver NEW)
            (check-size :schema isReferenceType :ver NEW)
            (compute-delta-index :schema isReferenceType :canonical-index (0))
            (clear-relation :schema isReferenceType :ver NEW)
            (merge-index :index (isReferenceType 0))
            (rebuild-index :index (isReferenceType 0) :ver NEW)
            (check-size :schema isReferenceType :ver NEW)
            (compute-delta-index :schema isReferenceType :canonical-index (0))
            (clear-relation :schema isReferenceType :ver NEW)
            (merge-index :index (isReferenceType 0))
            (rebuild-index :index (isClassType_IDB 0) :ver NEW)
            (check-size :schema isClassType_IDB :ver NEW)
            (compute-delta-index :schema isClassType_IDB :canonical-index (0))
            (clear-relation :schema isClassType_IDB :ver NEW)
            (merge-index :index (isClassType_IDB 0))
            (rebuild-index :index (isArrayType_IDB 0) :ver NEW)
            (check-size :schema isArrayType_IDB :ver NEW)
            (compute-delta-index :schema isArrayType_IDB :canonical-index (0))
            (clear-relation :schema isArrayType_IDB :ver NEW)
            (merge-index :index (isArrayType_IDB 0))
            (rebuild-index :index (isInterfaceType_IDB 0) :ver NEW)
            (check-size :schema isInterfaceType_IDB :ver NEW)
            (compute-delta-index :schema isInterfaceType_IDB :canonical-index (0))
            (clear-relation :schema isInterfaceType_IDB :ver NEW)
            (merge-index :index (isInterfaceType_IDB 0))
            (rebuild-index :index (DirectSubclass 0 1) :ver NEW)
            (check-size :schema DirectSubclass :ver NEW)
            (compute-delta-index :schema DirectSubclass :canonical-index (0 1))
            (clear-relation :schema DirectSubclass :ver NEW)
            (merge-index :index (DirectSubclass 0 1))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel isType :canonical-index (0))
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel isReferenceType :canonical-index (0))
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel isClassType_IDB :canonical-index (0))
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel isArrayType_IDB :canonical-index (0))
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel isInterfaceType_IDB :canonical-index (0))
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel DirectSubclass :canonical-index (0 1))
  )
  (step :recursive false
        (fixpoint-plan
            (execute-pipeline :rule Superinterface_Base
              :sources (tuple
                (index-spec :schema DirectSuperinterface :index (0 1) :ver FULL))
              :dests (tuple
                (index-spec :schema Superinterface :index (1 0) :ver FULL))
                (scan :vars (c k) :index (DirectSuperinterface 0 1) :ver FULL :prefix ())
                (insert-into :schema Superinterface :ver NEW :dedup-index (1 0) :terms (k c))
            )
            (rebuild-index :index (Superinterface 1 0) :ver NEW)
            (check-size :schema Superinterface :ver NEW)
            (compute-delta-index :schema Superinterface :canonical-index (1 0))
            (clear-relation :schema Superinterface :ver NEW)
            (merge-index :index (Superinterface 1 0))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel Superinterface :canonical-index (1 0))
  )
  (step :recursive true
        (fixpoint-plan
            (parallel-group  ;; 2 independent ops
                (execute-pipeline :rule Superinterface_Trans_D0
                  :sources (tuple
                    (index-spec :schema Superinterface :index (1 0) :ver DELTA)
                    (index-spec :schema DirectSuperinterface :index (1 0) :ver FULL)
                    (index-spec :schema Superinterface :index (1 0) :ver DELTA)
                    (index-spec :schema DirectSuperinterface :index (1 0) :ver FULL))
                  :dests (tuple
                    (index-spec :schema Superinterface :index (1 0) :ver FULL))
                    (column-join :var b
                      :sources (
                        (column-source :index (Superinterface 1 0) :ver DELTA :prefix ())
                        (column-source :index (DirectSuperinterface 1 0) :ver FULL :prefix ())
                      ))
                    (cartesian-join :vars (k c) :var-from-source ((k) (c))
                      :sources (
                        (column-source :index (Superinterface 1 0) :ver DELTA :prefix (b))
                        (column-source :index (DirectSuperinterface 1 0) :ver FULL :prefix (b))
                      ))
                    (insert-into :schema Superinterface :ver NEW :dedup-index (1 0) :terms (k c))
                )
                (execute-pipeline :rule Superinterface_Inherit_D0
                  :sources (tuple
                    (index-spec :schema Superinterface :index (1 0) :ver DELTA)
                    (index-spec :schema DirectSuperclass :index (1 0) :ver FULL)
                    (index-spec :schema Superinterface :index (1 0) :ver DELTA)
                    (index-spec :schema DirectSuperclass :index (1 0) :ver FULL))
                  :dests (tuple
                    (index-spec :schema Superinterface :index (1 0) :ver FULL))
                    (column-join :var b
                      :sources (
                        (column-source :index (Superinterface 1 0) :ver DELTA :prefix ())
                        (column-source :index (DirectSuperclass 1 0) :ver FULL :prefix ())
                      ))
                    (cartesian-join :vars (k c) :var-from-source ((k) (c))
                      :sources (
                        (column-source :index (Superinterface 1 0) :ver DELTA :prefix (b))
                        (column-source :index (DirectSuperclass 1 0) :ver FULL :prefix (b))
                      ))
                    (insert-into :schema Superinterface :ver NEW :dedup-index (1 0) :terms (k c))
                )
            )
            (rebuild-index :index (Superinterface 1 0) :ver NEW)
            (clear-relation :schema Superinterface :ver DELTA)
            (check-size :schema Superinterface :ver NEW)
            (compute-delta-index :schema Superinterface :canonical-index (1 0))
            (clear-relation :schema Superinterface :ver NEW)
            (merge-index :index (Superinterface 1 0))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel Superinterface :canonical-index (1 0))
  )
  (step :recursive false
        (fixpoint-plan
            (parallel-group  ;; 4 independent ops
                (execute-pipeline :rule MethodImplemented
                  :sources (tuple
                    (index-spec :schema Method_SimpleName :index (0 1) :ver FULL)
                    (index-spec :schema Method_Descriptor :index (0 1) :ver FULL)
                    (index-spec :schema Method_DeclaringType :index (0 1) :ver FULL)
                    (index-spec :schema Method_SimpleName :index (0 1) :ver FULL)
                    (index-spec :schema Method_Descriptor :index (0 1) :ver FULL)
                    (index-spec :schema Method_DeclaringType :index (0 1) :ver FULL)
                    (index-spec :schema Method_Modifier :index (0 1) :ver FULL))
                  :dests (tuple
                    (index-spec :schema MethodImplemented :index (0 1 2 3) :ver FULL))
                    (column-join :var meth
                      :sources (
                        (column-source :index (Method_SimpleName 0 1) :ver FULL :prefix ())
                        (column-source :index (Method_Descriptor 0 1) :ver FULL :prefix ())
                        (column-source :index (Method_DeclaringType 0 1) :ver FULL :prefix ())
                      ))
                    (cartesian-join :vars (simplename descriptor mtype) :var-from-source ((simplename) (descriptor) (mtype))
                      :sources (
                        (column-source :index (Method_SimpleName 0 1) :ver FULL :prefix (meth))
                        (column-source :index (Method_Descriptor 0 1) :ver FULL :prefix (meth))
                        (column-source :index (Method_DeclaringType 0 1) :ver FULL :prefix (meth))
                      ))
                    (negation :schema Method_Modifier :ver FULL :index (Method_Modifier 0 1) :prefix (meth))
                    (insert-into :schema MethodImplemented :ver NEW :dedup-index (0 1 2 3) :terms (simplename descriptor mtype meth))
                )
                (execute-pipeline :rule MainMethodDecl_Base
                  :sources (tuple
                    (index-spec :schema MainClass :index (0) :ver FULL)
                    (index-spec :schema Method_DeclaringType :index (1 0) :ver FULL)
                    (index-spec :schema Method_DeclaringType :index (1 0) :ver FULL)
                    (index-spec :schema Method_SimpleName :index (0 1) :ver FULL)
                    (index-spec :schema Method_Descriptor :index (0 1) :ver FULL)
                    (index-spec :schema Method_Modifier :index (1 0) :ver FULL)
                    (index-spec :schema Method_Modifier :index (1 0) :ver FULL)
                    (index-spec :schema Method_SimpleName :index (0 1) :ver FULL)
                    (index-spec :schema Method_Descriptor :index (0 1) :ver FULL)
                    (index-spec :schema Method_Modifier :index (1 0) :ver FULL)
                    (index-spec :schema Method_Modifier :index (1 0) :ver FULL))
                  :dests (tuple
                    (index-spec :schema MainMethodDeclaration :index (0) :ver FULL))
                    (column-join :var mtype
                      :sources (
                        (column-source :index (MainClass 0) :ver FULL :prefix ())
                        (column-source :index (Method_DeclaringType 1 0) :ver FULL :prefix ())
                      ))
                    (column-join :var meth
                      :sources (
                        (column-source :index (Method_DeclaringType 1 0) :ver FULL :prefix (mtype))
                        (column-source :index (Method_SimpleName 0 1) :ver FULL :prefix ())
                        (column-source :index (Method_Descriptor 0 1) :ver FULL :prefix ())
                        (column-source :index (Method_Modifier 1 0) :ver FULL :prefix ())
                        (column-source :index (Method_Modifier 1 0) :ver FULL :prefix ())
                      ))
                    (cartesian-join :vars (_c0 _c1 _c2 _c3) :var-from-source ((_c0) (_c1) (_c2) (_c3))
                      :sources (
                        (column-source :index (Method_SimpleName 0 1) :ver FULL :prefix (meth))
                        (column-source :index (Method_Descriptor 0 1) :ver FULL :prefix (meth))
                        (column-source :index (Method_Modifier 1 0) :ver FULL :prefix (meth))
                        (column-source :index (Method_Modifier 1 0) :ver FULL :prefix (meth))
                      ))
                    (filter :vars (_c0) :code "return _c0 == 1004;")
                    (filter :vars (_c1) :code "return _c1 == 1005;")
                    (filter :vars (_c2) :code "return _c2 == 1002;")
                    (filter :vars (_c3) :code "return _c3 == 1003;")
                    (filter :vars (meth) :code "return meth != 1011 && meth != 1012 && meth != 1013;")
                    (insert-into :schema MainMethodDeclaration :ver NEW :dedup-index (0) :terms (meth))
                )
                (execute-pipeline :rule MIBase_Virtual
                  :sources (tuple
                    (index-spec :schema VirtualMethodInvocation_Base :index (0 1) :ver FULL))
                  :dests (tuple
                    (index-spec :schema MethodInvocation_Base :index (0 1) :ver FULL))
                    (scan :vars (inv base) :index (VirtualMethodInvocation_Base 0 1) :ver FULL :prefix ())
                    (insert-into :schema MethodInvocation_Base :ver NEW :dedup-index (0 1) :terms (inv base))
                )
                (execute-pipeline :rule MIBase_Special
                  :sources (tuple
                    (index-spec :schema SpecialMethodInvocation_Base :index (0 1) :ver FULL))
                  :dests (tuple
                    (index-spec :schema MethodInvocation_Base :index (0 1) :ver FULL))
                    (scan :vars (inv base) :index (SpecialMethodInvocation_Base 0 1) :ver FULL :prefix ())
                    (insert-into :schema MethodInvocation_Base :ver NEW :dedup-index (0 1) :terms (inv base))
                )
            )
            (rebuild-index :index (MethodImplemented 0 1 2 3) :ver NEW)
            (check-size :schema MethodImplemented :ver NEW)
            (compute-delta-index :schema MethodImplemented :canonical-index (0 1 2 3))
            (clear-relation :schema MethodImplemented :ver NEW)
            (merge-index :index (MethodImplemented 0 1 2 3))
            (rebuild-index :index (MainMethodDeclaration 0) :ver NEW)
            (check-size :schema MainMethodDeclaration :ver NEW)
            (compute-delta-index :schema MainMethodDeclaration :canonical-index (0))
            (clear-relation :schema MainMethodDeclaration :ver NEW)
            (merge-index :index (MainMethodDeclaration 0))
            (rebuild-index :index (MethodInvocation_Base 0 1) :ver NEW)
            (check-size :schema MethodInvocation_Base :ver NEW)
            (compute-delta-index :schema MethodInvocation_Base :canonical-index (0 1))
            (clear-relation :schema MethodInvocation_Base :ver NEW)
            (merge-index :index (MethodInvocation_Base 0 1))
            (rebuild-index :index (MethodInvocation_Base 0 1) :ver NEW)
            (check-size :schema MethodInvocation_Base :ver NEW)
            (compute-delta-index :schema MethodInvocation_Base :canonical-index (0 1))
            (clear-relation :schema MethodInvocation_Base :ver NEW)
            (merge-index :index (MethodInvocation_Base 0 1))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel MethodImplemented :canonical-index (0 1 2 3))
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel MainMethodDeclaration :canonical-index (0))
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel MethodInvocation_Base :canonical-index (0 1))
  )
  (step :recursive false
        (fixpoint-plan
            (execute-pipeline :rule Subclass_Base
              :sources (tuple
                (index-spec :schema DirectSubclass :index (0 1) :ver FULL))
              :dests (tuple
                (index-spec :schema Subclass :index (0 1) :ver FULL))
                (scan :vars (a c) :index (DirectSubclass 0 1) :ver FULL :prefix ())
                (insert-into :schema Subclass :ver NEW :dedup-index (0 1) :terms (c a))
            )
            (rebuild-index :index (Subclass 0 1) :ver NEW)
            (check-size :schema Subclass :ver NEW)
            (compute-delta-index :schema Subclass :canonical-index (0 1))
            (clear-relation :schema Subclass :ver NEW)
            (merge-index :index (Subclass 0 1))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel Subclass :canonical-index (0 1))
  )
  (step :recursive true
        (fixpoint-plan
            (execute-pipeline :rule Subclass_Trans_D0
              :sources (tuple
                (index-spec :schema Subclass :index (0 1) :ver DELTA)
                (index-spec :schema DirectSubclass :index (0 1) :ver FULL)
                (index-spec :schema Subclass :index (0 1) :ver DELTA)
                (index-spec :schema DirectSubclass :index (0 1) :ver FULL))
              :dests (tuple
                (index-spec :schema Subclass :index (0 1) :ver FULL))
                (column-join :var b
                  :sources (
                    (column-source :index (Subclass 0 1) :ver DELTA :prefix ())
                    (column-source :index (DirectSubclass 0 1) :ver FULL :prefix ())
                  ))
                (cartesian-join :vars (a c) :var-from-source ((a) (c))
                  :sources (
                    (column-source :index (Subclass 0 1) :ver DELTA :prefix (b))
                    (column-source :index (DirectSubclass 0 1) :ver FULL :prefix (b))
                  ))
                (insert-into :schema Subclass :ver NEW :dedup-index (0 1) :terms (c a))
            )
            (rebuild-index :index (Subclass 0 1) :ver NEW)
            (clear-relation :schema Subclass :ver DELTA)
            (check-size :schema Subclass :ver NEW)
            (compute-delta-index :schema Subclass :canonical-index (0 1))
            (clear-relation :schema Subclass :ver NEW)
            (merge-index :index (Subclass 0 1))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel Subclass :canonical-index (0 1))
  )
  (step :recursive false
        (fixpoint-plan
            (execute-pipeline :rule Superclass
              :sources (tuple
                (index-spec :schema Subclass :index (0 1) :ver FULL))
              :dests (tuple
                (index-spec :schema Superclass :index (0 1) :ver FULL))
                (scan :vars (a c) :index (Subclass 0 1) :ver FULL :prefix ())
                (insert-into :schema Superclass :ver NEW :dedup-index (0 1) :terms (c a))
            )
            (rebuild-index :index (Superclass 0 1) :ver NEW)
            (check-size :schema Superclass :ver NEW)
            (compute-delta-index :schema Superclass :canonical-index (0 1))
            (clear-relation :schema Superclass :ver NEW)
            (merge-index :index (Superclass 0 1))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel Superclass :canonical-index (0 1))
  )
  (step :recursive false
        (fixpoint-plan
            (parallel-group  ;; 10 independent ops
                (execute-pipeline :rule SubtypeOf_Refl_Class
                  :sources (tuple
                    (index-spec :schema isClassType_IDB :index (0) :ver FULL))
                  :dests (tuple
                    (index-spec :schema SubtypeOf :index (0 1) :ver FULL))
                    (scan :vars (s) :index (isClassType_IDB 0) :ver FULL :prefix ())
                    (insert-into :schema SubtypeOf :ver NEW :dedup-index (0 1) :terms (s s))
                )
                (execute-pipeline :rule SubtypeOf_Refl_Type
                  :sources (tuple
                    (index-spec :schema isType :index (0) :ver FULL))
                  :dests (tuple
                    (index-spec :schema SubtypeOf :index (0 1) :ver FULL))
                    (scan :vars (t) :index (isType 0) :ver FULL :prefix ())
                    (insert-into :schema SubtypeOf :ver NEW :dedup-index (0 1) :terms (t t))
                )
                (execute-pipeline :rule SubtypeOf_Refl_Interface
                  :sources (tuple
                    (index-spec :schema isInterfaceType_IDB :index (0) :ver FULL))
                  :dests (tuple
                    (index-spec :schema SubtypeOf :index (0 1) :ver FULL))
                    (scan :vars (s) :index (isInterfaceType_IDB 0) :ver FULL :prefix ())
                    (insert-into :schema SubtypeOf :ver NEW :dedup-index (0 1) :terms (s s))
                )
                (execute-pipeline :rule SubtypeOf_Subclass
                  :sources (tuple
                    (index-spec :schema Subclass :index (0 1) :ver FULL))
                  :dests (tuple
                    (index-spec :schema SubtypeOf :index (0 1) :ver FULL))
                    (scan :vars (t s) :index (Subclass 0 1) :ver FULL :prefix ())
                    (insert-into :schema SubtypeOf :ver NEW :dedup-index (0 1) :terms (s t))
                )
                (execute-pipeline :rule SubtypeOf_Class_Iface
                  :sources (tuple
                    (index-spec :schema isClassType_IDB :index (0) :ver FULL)
                    (index-spec :schema Superinterface :index (1 0) :ver FULL)
                    (index-spec :schema Superinterface :index (1 0) :ver FULL))
                  :dests (tuple
                    (index-spec :schema SubtypeOf :index (0 1) :ver FULL))
                    (column-join :var s
                      :sources (
                        (column-source :index (isClassType_IDB 0) :ver FULL :prefix ())
                        (column-source :index (Superinterface 1 0) :ver FULL :prefix ())
                      ))
                    (cartesian-join :vars (t) :var-from-source ((t))
                      :sources (
