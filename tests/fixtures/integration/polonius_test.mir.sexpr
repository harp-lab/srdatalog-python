                    (column-source :index (origin_contains_loan_on_entry 0 2 1) :ver FULL :prefix (origin point))
                  ))
                (insert-into :schema loan_live_at :ver NEW :dedup-index (0 1) :terms (loan point))
            )
            (rebuild-index :index (loan_live_at 0 1) :ver NEW)
            (check-size :schema loan_live_at :ver NEW)
            (compute-delta-index :schema loan_live_at :canonical-index (0 1))
            (clear-relation :schema loan_live_at :ver NEW)
            (merge-index :index (loan_live_at 0 1))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel loan_live_at :canonical-index (0 1))
  )
  (step :recursive false
        (fixpoint-plan
            (parallel-group  ;; 2 independent ops
                (execute-pipeline :rule errors_rule
                  :sources (tuple
                    (index-spec :schema loan_invalidated_at :index (0 1) :ver FULL)
                    (index-spec :schema loan_live_at :index (0 1) :ver FULL)
                    (index-spec :schema loan_invalidated_at :index (0 1) :ver FULL)
                    (index-spec :schema loan_live_at :index (0 1) :ver FULL))
                  :dests (tuple
                    (index-spec :schema errors :index (0 1) :ver FULL))
                    (column-join :var loan
                      :sources (
                        (column-source :index (loan_invalidated_at 0 1) :ver FULL :prefix ())
                        (column-source :index (loan_live_at 0 1) :ver FULL :prefix ())
                      ))
                    (column-join :var point
                      :sources (
                        (column-source :index (loan_invalidated_at 0 1) :ver FULL :prefix (loan))
                        (column-source :index (loan_live_at 0 1) :ver FULL :prefix (loan))
                      ))
                    (insert-into :schema errors :ver NEW :dedup-index (0 1) :terms (loan point))
                )
                (execute-pipeline :rule subset_error_rule
                  :sources (tuple
                    (index-spec :schema subset :index (0 1 2) :ver FULL)
                    (index-spec :schema placeholder_origin :index (0) :ver FULL)
                    (index-spec :schema subset :index (0 1 2) :ver FULL)
                    (index-spec :schema placeholder_origin :index (0) :ver FULL)
                    (index-spec :schema subset :index (0 1 2) :ver FULL)
                    (index-spec :schema known_placeholder_subset :index (0 1) :ver FULL))
                  :dests (tuple
                    (index-spec :schema subset_error :index (0 1 2) :ver FULL))
                    (column-join :var origin1
                      :sources (
                        (column-source :index (subset 0 1 2) :ver FULL :prefix ())
                        (column-source :index (placeholder_origin 0) :ver FULL :prefix ())
                      ))
                    (column-join :var origin2
                      :sources (
                        (column-source :index (subset 0 1 2) :ver FULL :prefix (origin1))
                        (column-source :index (placeholder_origin 0) :ver FULL :prefix ())
                      ))
                    (cartesian-join :vars (point) :var-from-source ((point))
                      :sources (
                        (column-source :index (subset 0 1 2) :ver FULL :prefix (origin1 origin2))
                      ))
                    (negation :schema known_placeholder_subset :ver FULL :index (known_placeholder_subset 0 1) :prefix (origin1 origin2))
                    (filter :vars (origin1 origin2) :code "return origin1 != origin2;")
                    (insert-into :schema subset_error :ver NEW :dedup-index (0 1 2) :terms (origin1 origin2 point))
                )
            )
            (rebuild-index :index (errors 0 1) :ver NEW)
            (check-size :schema errors :ver NEW)
            (compute-delta-index :schema errors :canonical-index (0 1))
            (clear-relation :schema errors :ver NEW)
            (merge-index :index (errors 0 1))
            (rebuild-index :index (subset_error 0 1 2) :ver NEW)
            (check-size :schema subset_error :ver NEW)
            (compute-delta-index :schema subset_error :canonical-index (0 1 2))
            (clear-relation :schema subset_error :ver NEW)
            (merge-index :index (subset_error 0 1 2))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel errors :canonical-index (0 1))
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel subset_error :canonical-index (0 1 2))
  )
  (step :recursive false
        (fixpoint-plan
            (execute-pipeline :rule path_accessed_at_base_rule
              :sources (tuple
                (index-spec :schema path_accessed_at_base :index (0 1) :ver FULL))
              :dests (tuple
                (index-spec :schema path_accessed_at :index (0 1) :ver FULL))
                (scan :vars (x y) :index (path_accessed_at_base 0 1) :ver FULL :prefix ())
                (insert-into :schema path_accessed_at :ver NEW :dedup-index (0 1) :terms (x y))
            )
            (rebuild-index :index (path_accessed_at 0 1) :ver NEW)
            (check-size :schema path_accessed_at :ver NEW)
            (compute-delta-index :schema path_accessed_at :canonical-index (0 1))
            (clear-relation :schema path_accessed_at :ver NEW)
            (merge-index :index (path_accessed_at 0 1))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel path_accessed_at :canonical-index (0 1))
  )
  (step :recursive true
        (fixpoint-plan
            (execute-pipeline :rule path_accessed_at_ancestor_D0
              :sources (tuple
                (index-spec :schema path_accessed_at :index (0 1) :ver DELTA)
                (index-spec :schema ancestor_path :index (0 1) :ver FULL)
                (index-spec :schema path_accessed_at :index (0 1) :ver DELTA)
                (index-spec :schema ancestor_path :index (0 1) :ver FULL))
              :dests (tuple
                (index-spec :schema path_accessed_at :index (0 1) :ver FULL))
                (column-join :var parent
                  :sources (
                    (column-source :index (path_accessed_at 0 1) :ver DELTA :prefix ())
                    (column-source :index (ancestor_path 0 1) :ver FULL :prefix ())
                  ))
                (cartesian-join :vars (point child) :var-from-source ((point) (child))
                  :sources (
                    (column-source :index (path_accessed_at 0 1) :ver DELTA :prefix (parent))
                    (column-source :index (ancestor_path 0 1) :ver FULL :prefix (parent))
                  ))
                (insert-into :schema path_accessed_at :ver NEW :dedup-index (0 1) :terms (child point))
            )
            (rebuild-index :index (path_accessed_at 0 1) :ver NEW)
            (clear-relation :schema path_accessed_at :ver DELTA)
            (check-size :schema path_accessed_at :ver NEW)
            (compute-delta-index :schema path_accessed_at :canonical-index (0 1))
            (clear-relation :schema path_accessed_at :ver NEW)
            (merge-index :index (path_accessed_at 0 1))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel path_accessed_at :canonical-index (0 1))
  )
  (step :recursive false
        (fixpoint-plan
            (execute-pipeline :rule pmuoe_moved
              :sources (tuple
                (index-spec :schema path_moved_at :index (0 1) :ver FULL))
              :dests (tuple
                (index-spec :schema path_maybe_uninitialized_on_exit :index (1 0) :ver FULL))
                (scan :vars (path point) :index (path_moved_at 0 1) :ver FULL :prefix ())
                (insert-into :schema path_maybe_uninitialized_on_exit :ver NEW :dedup-index (1 0) :terms (path point))
            )
            (rebuild-index :index (path_maybe_uninitialized_on_exit 1 0) :ver NEW)
            (check-size :schema path_maybe_uninitialized_on_exit :ver NEW)
            (compute-delta-index :schema path_maybe_uninitialized_on_exit :canonical-index (1 0))
            (clear-relation :schema path_maybe_uninitialized_on_exit :ver NEW)
            (merge-index :index (path_maybe_uninitialized_on_exit 1 0))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel path_maybe_uninitialized_on_exit :canonical-index (1 0))
  )
  (step :recursive true
        (fixpoint-plan
            (execute-pipeline :rule pmuoe_cfg_D0
              :sources (tuple
                (index-spec :schema path_maybe_uninitialized_on_exit :index (1 0) :ver DELTA)
                (index-spec :schema cfg_edge :index (0 1) :ver FULL)
                (index-spec :schema path_maybe_uninitialized_on_exit :index (1 0) :ver DELTA)
                (index-spec :schema cfg_edge :index (0 1) :ver FULL)
                (index-spec :schema path_assigned_at :index (1 0) :ver FULL))
              :dests (tuple
                (index-spec :schema path_maybe_uninitialized_on_exit :index (1 0) :ver FULL))
                (column-join :var point1
                  :sources (
                    (column-source :index (path_maybe_uninitialized_on_exit 1 0) :ver DELTA :prefix ())
                    (column-source :index (cfg_edge 0 1) :ver FULL :prefix ())
                  ))
                (cartesian-join :vars (point2 path) :var-from-source ((path) (point2))
                  :sources (
                    (column-source :index (path_maybe_uninitialized_on_exit 1 0) :ver DELTA :prefix (point1))
                    (column-source :index (cfg_edge 0 1) :ver FULL :prefix (point1))
                  ))
                (negation :schema path_assigned_at :ver FULL :index (path_assigned_at 1 0) :prefix (point2 path))
                (insert-into :schema path_maybe_uninitialized_on_exit :ver NEW :dedup-index (1 0) :terms (path point2))
            )
            (rebuild-index :index (path_maybe_uninitialized_on_exit 1 0) :ver NEW)
            (clear-relation :schema path_maybe_uninitialized_on_exit :ver DELTA)
            (check-size :schema path_maybe_uninitialized_on_exit :ver NEW)
            (compute-delta-index :schema path_maybe_uninitialized_on_exit :canonical-index (1 0))
            (clear-relation :schema path_maybe_uninitialized_on_exit :ver NEW)
            (merge-index :index (path_maybe_uninitialized_on_exit 1 0))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel path_maybe_uninitialized_on_exit :canonical-index (1 0))
  )
  (step :recursive false
        (fixpoint-plan
            (execute-pipeline :rule move_error_rule
              :sources (tuple
                (index-spec :schema path_maybe_uninitialized_on_exit :index (1 0) :ver FULL)
                (index-spec :schema cfg_edge :index (0 1) :ver FULL)
                (index-spec :schema path_maybe_uninitialized_on_exit :index (1 0) :ver FULL)
                (index-spec :schema cfg_edge :index (0 1) :ver FULL))
              :dests (tuple
                (index-spec :schema move_error :index (0 1) :ver FULL))
                (column-join :var src
                  :sources (
                    (column-source :index (path_maybe_uninitialized_on_exit 1 0) :ver FULL :prefix ())
                    (column-source :index (cfg_edge 0 1) :ver FULL :prefix ())
                  ))
                (cartesian-join :vars (path tgt) :var-from-source ((path) (tgt))
                  :sources (
                    (column-source :index (path_maybe_uninitialized_on_exit 1 0) :ver FULL :prefix (src))
                    (column-source :index (cfg_edge 0 1) :ver FULL :prefix (src))
                  ))
                (insert-into :schema move_error :ver NEW :dedup-index (0 1) :terms (path tgt))
            )
            (rebuild-index :index (move_error 0 1) :ver NEW)
            (check-size :schema move_error :ver NEW)
            (compute-delta-index :schema move_error :canonical-index (0 1))
            (clear-relation :schema move_error :ver NEW)
            (merge-index :index (move_error 0 1))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel move_error :canonical-index (0 1))
  )
)