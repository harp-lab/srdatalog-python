                    (column-source :index (cfg_edge 0 1) :ver FULL :prefix (point1))
                  ))
                (negation :schema path_moved_at :ver FULL :index (path_moved_at 1 0) :prefix (point2 path))
                (insert-into :schema path_maybe_initialized_on_exit :ver NEW :dedup-index (1 0) :terms (path point2))
            )
            (rebuild-index :index (path_maybe_initialized_on_exit 1 0) :ver NEW)
