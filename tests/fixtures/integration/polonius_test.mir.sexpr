                (scan :vars (path point) :index (path_assigned_at 0 1) :ver FULL :prefix ())
                (insert-into :schema path_maybe_initialized_on_exit :ver NEW :dedup-index (1 0) :terms (path point))
            )
            (rebuild-index :index (path_maybe_initialized_on_exit 1 0) :ver NEW)
            (check-size :schema path_maybe_initialized_on_exit :ver NEW)
