            (rebuild-index-from-index :source (path_maybe_initialized_on_exit 1 0) :target (path_maybe_initialized_on_exit 0 1) :ver DELTA)
            (merge-index :index (path_maybe_initialized_on_exit 0 1))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel path_maybe_initialized_on_exit :canonical-index (1 0))
  )
  (step :recursive true
        (fixpoint-plan
            (execute-pipeline :rule pmioe_cfg_D0
              :sources (tuple
                (index-spec :schema path_maybe_initialized_on_exit :index (1 0) :ver DELTA)
                (index-spec :schema cfg_edge :index (0 1) :ver FULL)
                (index-spec :schema path_maybe_initialized_on_exit :index (1 0) :ver DELTA)
                (index-spec :schema cfg_edge :index (0 1) :ver FULL)
                (index-spec :schema path_moved_at :index (1 0) :ver FULL))
              :dests (tuple
                (index-spec :schema path_maybe_initialized_on_exit :index (1 0) :ver FULL))
                (column-join :var point1
                  :sources (
                    (column-source :index (path_maybe_initialized_on_exit 1 0) :ver DELTA :prefix ())
                    (column-source :index (cfg_edge 0 1) :ver FULL :prefix ())
                  ))
                (cartesian-join :vars (point2 path) :var-from-source ((path) (point2))
                  :sources (
