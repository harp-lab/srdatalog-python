(program
  (step :recursive false
        (fixpoint-plan
            (parallel-group  ;; 2 independent ops
                (execute-pipeline :rule cfg_node_from_edge_src
                  :sources (tuple
                    (index-spec :schema cfg_edge :index (0 1) :ver FULL))
                  :dests (tuple
                    (index-spec :schema cfg_node :index (0) :ver FULL))
                    (scan :vars (point1 _gen1) :index (cfg_edge 0 1) :ver FULL :prefix ())
                    (insert-into :schema cfg_node :ver NEW :dedup-index (0) :terms (point1))
                )
                (execute-pipeline :rule cfg_node_from_edge_dst
                  :sources (tuple
                    (index-spec :schema cfg_edge :index (0 1) :ver FULL))
                  :dests (tuple
                    (index-spec :schema cfg_node :index (0) :ver FULL))
                    (scan :vars (_gen2 point2) :index (cfg_edge 0 1) :ver FULL :prefix ())
                    (insert-into :schema cfg_node :ver NEW :dedup-index (0) :terms (point2))
                )
            )
            (rebuild-index :index (cfg_node 0) :ver NEW)
            (check-size :schema cfg_node :ver NEW)
            (compute-delta-index :schema cfg_node :canonical-index (0))
            (clear-relation :schema cfg_node :ver NEW)
            (merge-index :index (cfg_node 0))
            (rebuild-index :index (cfg_node 0) :ver NEW)
            (check-size :schema cfg_node :ver NEW)
            (compute-delta-index :schema cfg_node :canonical-index (0))
            (clear-relation :schema cfg_node :ver NEW)
            (merge-index :index (cfg_node 0))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel cfg_node :canonical-index (0))
  )
  (step :recursive false
        (fixpoint-plan
            (execute-pipeline :rule ancestor_path_base
              :sources (tuple
                (index-spec :schema child_path :index (0 1) :ver FULL))
              :dests (tuple
                (index-spec :schema ancestor_path :index (0 1) :ver FULL))
                (scan :vars (x y) :index (child_path 0 1) :ver FULL :prefix ())
                (insert-into :schema ancestor_path :ver NEW :dedup-index (0 1) :terms (x y))
            )
            (rebuild-index :index (ancestor_path 0 1) :ver NEW)
            (check-size :schema ancestor_path :ver NEW)
            (compute-delta-index :schema ancestor_path :canonical-index (0 1))
            (clear-relation :schema ancestor_path :ver NEW)
            (merge-index :index (ancestor_path 0 1))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel ancestor_path :canonical-index (0 1))
  )
  (step :recursive true
        (fixpoint-plan
            (execute-pipeline :rule ancestor_path_trans_D0
              :sources (tuple
                (index-spec :schema ancestor_path :index (0 1) :ver DELTA)
                (index-spec :schema child_path :index (0 1) :ver FULL)
                (index-spec :schema ancestor_path :index (0 1) :ver DELTA)
                (index-spec :schema child_path :index (0 1) :ver FULL))
              :dests (tuple
                (index-spec :schema ancestor_path :index (0 1) :ver FULL))
                (column-join :var parent
                  :sources (
                    (column-source :index (ancestor_path 0 1) :ver DELTA :prefix ())
                    (column-source :index (child_path 0 1) :ver FULL :prefix ())
                  ))
                (cartesian-join :vars (child grandparent) :var-from-source ((child) (grandparent))
                  :sources (
                    (column-source :index (ancestor_path 0 1) :ver DELTA :prefix (parent))
                    (column-source :index (child_path 0 1) :ver FULL :prefix (parent))
                  ))
                (insert-into :schema ancestor_path :ver NEW :dedup-index (0 1) :terms (grandparent child))
            )
            (rebuild-index :index (ancestor_path 0 1) :ver NEW)
            (clear-relation :schema ancestor_path :ver DELTA)
            (check-size :schema ancestor_path :ver NEW)
            (compute-delta-index :schema ancestor_path :canonical-index (0 1))
            (clear-relation :schema ancestor_path :ver NEW)
            (merge-index :index (ancestor_path 0 1))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel ancestor_path :canonical-index (0 1))
  )
  (step :recursive false
        (fixpoint-plan
            (execute-pipeline :rule pbwv_base
              :sources (tuple
                (index-spec :schema path_is_var :index (0 1) :ver FULL))
              :dests (tuple
                (index-spec :schema path_begins_with_var :index (0 1) :ver FULL))
                (scan :vars (x vr) :index (path_is_var 0 1) :ver FULL :prefix ())
                (insert-into :schema path_begins_with_var :ver NEW :dedup-index (0 1) :terms (x vr))
            )
            (rebuild-index :index (path_begins_with_var 0 1) :ver NEW)
            (check-size :schema path_begins_with_var :ver NEW)
            (compute-delta-index :schema path_begins_with_var :canonical-index (0 1))
            (clear-relation :schema path_begins_with_var :ver NEW)
            (merge-index :index (path_begins_with_var 0 1))
        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel path_begins_with_var :canonical-index (0 1))
  )
  (step :recursive true
        (fixpoint-plan
            (execute-pipeline :rule pbwv_ancestor_D0
              :sources (tuple
                (index-spec :schema path_begins_with_var :index (0 1) :ver DELTA)
                (index-spec :schema ancestor_path :index (0 1) :ver FULL)
                (index-spec :schema path_begins_with_var :index (0 1) :ver DELTA)
                (index-spec :schema ancestor_path :index (0 1) :ver FULL))
              :dests (tuple
                (index-spec :schema path_begins_with_var :index (0 1) :ver FULL))
                (column-join :var parent
                  :sources (
                    (column-source :index (path_begins_with_var 0 1) :ver DELTA :prefix ())
                    (column-source :index (ancestor_path 0 1) :ver FULL :prefix ())
                  ))
                (cartesian-join :vars (v child) :var-from-source ((v) (child))
                  :sources (
                    (column-source :index (path_begins_with_var 0 1) :ver DELTA :prefix (parent))
                    (column-source :index (ancestor_path 0 1) :ver FULL :prefix (parent))
                  ))
                (insert-into :schema path_begins_with_var :ver NEW :dedup-index (0 1) :terms (child v))
            )
            (rebuild-index :index (path_begins_with_var 0 1) :ver NEW)
            (clear-relation :schema path_begins_with_var :ver DELTA)
            (check-size :schema path_begins_with_var :ver NEW)
            (compute-delta-index :schema path_begins_with_var :canonical-index (0 1))
            (clear-relation :schema path_begins_with_var :ver NEW)
            (merge-index :index (path_begins_with_var 0 1))
