                (insert-into :schema path_assigned_at :ver NEW :dedup-index (0 1) :terms (child point))
            )
            (rebuild-index :index (path_assigned_at 0 1) :ver NEW)
            (clear-relation :schema path_assigned_at :ver DELTA)
            (check-size :schema path_assigned_at :ver NEW)
            (compute-delta-index :schema path_assigned_at :canonical-index (0 1))
            (clear-relation :schema path_assigned_at :ver NEW)
            (merge-index :index (path_assigned_at 0 1))
