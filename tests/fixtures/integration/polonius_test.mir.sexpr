        )
  )
  (step :recursive false
        (post-stratum-reconstruct-intern-cols :rel path_maybe_initialized_on_exit :canonical-index (1 0))
  )
  (step :recursive false
        (rebuild-index :index (path_maybe_initialized_on_exit 0 1) :ver FULL)
  )
  (step :recursive false
        (fixpoint-plan
            (execute-pipeline :rule vmpioe_from_path
              :sources (tuple
